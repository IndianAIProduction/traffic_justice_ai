# =============================================================================
# Traffic Justice AI - Environment Configuration
# Copy this file to .env and fill in the values
# =============================================================================

# OpenAI
OPENAI_API_KEY=changeme_replace_with_long_random_string

# PostgreSQL
POSTGRES_USER=traffic_justice
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=traffic_justice_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ChromaDB (internal container port is 8000; mapped to host 8001)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# JWT Auth
JWT_SECRET_KEY=changeme_replace_with_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Evidence Encryption
EVIDENCE_ENCRYPTION_KEY=changeme_replace_with_long_random_string

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
