# Copy to `.env` at the repo root (never commit real secrets).
# Used by Docker Compose (postgres, backend, frontend) and by Pydantic Settings in the backend.

# --- Required for AI features ---
OPENAI_API_KEY=

# --- Auth (backend) ---
JWT_SECRET_KEY=changeme_replace_with_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Evidence encryption (Fernet key, url-safe base64) ---
EVIDENCE_ENCRYPTION_KEY=changeme_replace_with_fernet_key

# --- PostgreSQL (align with docker-compose unless you change the service) ---
POSTGRES_USER=traffic_justice
POSTGRES_PASSWORD=changeme
POSTGRES_DB=traffic_justice_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- ChromaDB (backend talks to the chromadb service on the Compose network) ---
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- CORS (JSON array string) ---
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# --- Rate limiting (requests per minute per IP, default SlowAPI) ---
RATE_LIMIT_PER_MINUTE=60

# --- Optional: SMTP (complaint email submission) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Traffic Justice AI
SMTP_USE_TLS=true

# --- Optional: frontend / Next.js (Compose sets BACKEND_INTERNAL_URL in Dockerfile flow; override if needed) ---
# BACKEND_INTERNAL_URL=http://backend:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000
